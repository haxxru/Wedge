spring:
  datasource:
    url: jdbc:mysql://localhost:3306/wedge?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password: your_password
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update
  security:
    oauth2:
      client:
        registration:
          kakao:
            client-id: your_kakao_client_id
            client-secret: your_kakao_client_secret
          google:
            client-id: your_google_client_id
            client-secret: your_google_client_secret

jwt:
  secret: local-dev-secret-key-must-be-at-least-256-bits-long-padding
